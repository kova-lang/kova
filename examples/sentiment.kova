// Sentiment classification pipeline
// Demonstrates Prob<T> type and resolve()

let review = "The product quality is outstanding!"

let probSentiment = AI("classify sentiment as positive, negative, or neutral", review)
let sentiment = resolve(probSentiment)

if sentiment == "positive" {
    respond { status: 200, body: { approved: true, sentiment: sentiment } }
}

respond { status: 200, body: { approved: false, sentiment: sentiment } }